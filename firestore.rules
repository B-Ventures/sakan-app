rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(buildingId) {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/buildings/$(buildingId)) &&
        ( !('ownerId' in get(/databases/$(database)/documents/buildings/$(buildingId)).data) || 
          get(/databases/$(database)/documents/buildings/$(buildingId)).data.ownerId == request.auth.uid );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User profiles
    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn() && request.auth.uid == userId
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 200;
      allow delete: if false;
    }

    // Buildings
    match /buildings/{buildingId} {
      allow get: if isSignedIn() && (resource == null || !('ownerId' in resource.data) || resource.data.ownerId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 200;
      allow update: if isSignedIn()
        && (resource == null || !('ownerId' in resource.data) || resource.data.ownerId == request.auth.uid)
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 200;
      allow delete: if isSignedIn() && (resource == null || !('ownerId' in resource.data) || resource.data.ownerId == request.auth.uid);
    }

    // Tenants under a building
    match /buildings/{buildingId}/tenants/{tenantId} {
      allow get, list: if isSignedIn() && isOwner(buildingId);
      allow create, update: if isSignedIn()
        && isOwner(buildingId)
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 200;
      allow delete: if isSignedIn() && isOwner(buildingId);
    }

    // Payments under a building
    match /buildings/{buildingId}/payments/{paymentId} {
      allow get, list: if isSignedIn() && isOwner(buildingId);
      allow create, update: if isSignedIn()
        && isOwner(buildingId)
        && request.resource.data.tenantName is string
        && request.resource.data.tenantName.size() <= 200;
      allow delete: if isSignedIn() && isOwner(buildingId);
    }

    // Expenses under a building
    match /buildings/{buildingId}/expenses/{expenseId} {
      allow get, list: if isSignedIn() && isOwner(buildingId);
      allow create, update: if isSignedIn()
        && isOwner(buildingId)
        && request.resource.data.title is string
        && request.resource.data.title.size() <= 200;
      allow delete: if isSignedIn() && isOwner(buildingId);
    }
  }
}
