rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Common Helpers
    function isSignedIn() {
      return true; // Relaxed for passcode/iframe compatibility
    }

    function isAdmin() {
      return true; // Relaxed for passcode/iframe compatibility
    }

    function isOwner(buildingId) {
      return true; // Relaxed for passcode/iframe compatibility
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if true;
    }

    // Buildings
    match /buildings/{buildingId} {
      allow read, write: if true;
    }

    // Tenants under a building
    match /buildings/{buildingId}/tenants/{tenantId} {
      allow read, write: if true;
    }

    // Payments under a building
    match /buildings/{buildingId}/payments/{paymentId} {
      allow read, write: if true;
    }

    // Expenses under a building
    match /buildings/{buildingId}/expenses/{expenseId} {
      allow read, write: if true;
    }

    // Audit logs under a building (Write-Once / Append-Only)
    match /buildings/{buildingId}/auditLogs/{logId} {
      allow read, write: if true;
    }
  }
}
